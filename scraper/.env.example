# ============================================================
# FlexMLS / Spark API Credentials
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it's already in .gitignore.
# ============================================================

# --- IDX Credentials ---
# Internet Data Exchange — public-facing listings, basic fields
# Rate limit: 1,500 requests / 5 min
# Use for: bulk listing searches, dashboard display
SPARK_IDX_CLIENT_ID=
SPARK_IDX_CLIENT_SECRET=
SPARK_IDX_API_KEY=
SPARK_IDX_ACCESS_TOKEN=
SPARK_IDX_REFRESH_TOKEN=
SPARK_IDX_OPENID_TOKEN=

# --- VOW Credentials ---
# Virtual Office Website — extended fields, price history, DOM details
# Rate limit: 4,000 requests / 5 min
# Use for: enriched lead data, registered-user context
SPARK_VOW_CLIENT_ID=
SPARK_VOW_CLIENT_SECRET=
SPARK_VOW_API_KEY=
SPARK_VOW_ACCESS_TOKEN=
SPARK_VOW_REFRESH_TOKEN=
SPARK_VOW_OPENID_TOKEN=

# --- Broker Back Office Credentials ---
# Full access — all fields, private remarks, off-market data
# Use for: highest-fidelity lead enrichment, internal tools
SPARK_BBO_CLIENT_ID=
SPARK_BBO_CLIENT_SECRET=
SPARK_BBO_API_KEY=
SPARK_BBO_ACCESS_TOKEN=
SPARK_BBO_REFRESH_TOKEN=
SPARK_BBO_OPENID_TOKEN=

# --- MLS Settings ---
# The MLS area/city to scope searches to
MLS_CITY=Lubbock
MLS_STATE=TX
# Base API URL — standard Spark endpoint
SPARK_API_BASE=https://sparkapi.com/v1
